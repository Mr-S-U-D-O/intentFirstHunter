{
  "entities": {
    "Scraper": {
      "title": "Scraper",
      "description": "A Reddit scraper configuration",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the scraper"
        },
        "subreddit": {
          "type": "string",
          "description": "Target subreddit without the r/ prefix"
        },
        "keyword": {
          "type": "string",
          "description": "Keyword to look for in posts"
        },
        "intervalMinutes": {
          "type": "number",
          "description": "Interval in minutes to run the scraper"
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused"],
          "description": "Current status of the scraper"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the scraper was created"
        },
        "lastRunAt": {
          "type": "timestamp",
          "description": "When the scraper last ran"
        },
        "userId": {
          "type": "string",
          "description": "Owner of the scraper"
        }
      },
      "required": ["name", "subreddit", "keyword", "intervalMinutes", "status", "createdAt", "userId"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A lead generated from a Reddit post",
      "type": "object",
      "properties": {
        "scraperId": {
          "type": "string",
          "description": "ID of the scraper that found this lead"
        },
        "subreddit": {
          "type": "string",
          "description": "Subreddit where the lead was found"
        },
        "keyword": {
          "type": "string",
          "description": "Keyword that matched"
        },
        "postTitle": {
          "type": "string",
          "description": "Title of the Reddit post"
        },
        "postUrl": {
          "type": "string",
          "description": "URL of the Reddit post"
        },
        "postAuthor": {
          "type": "string",
          "description": "Author of the Reddit post"
        },
        "postContent": {
          "type": "string",
          "description": "Content of the Reddit post"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the lead was found and saved"
        },
        "userId": {
          "type": "string",
          "description": "Owner of the lead"
        }
      },
      "required": ["scraperId", "subreddit", "keyword", "postTitle", "postUrl", "postAuthor", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/scrapers/{scraperId}": {
      "schema": {
        "$ref": "#/entities/Scraper"
      },
      "description": "Stores scraper configurations"
    },
    "/leads/{leadId}": {
      "schema": {
        "$ref": "#/entities/Lead"
      },
      "description": "Stores leads generated by scrapers"
    }
  }
}
